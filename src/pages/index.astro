---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import InfiniteCanvas from '../components/InfiniteCanvas';
import { getAllImages, groupByDay } from '../lib/images';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const images = getAllImages(base);
const groups = groupByDay(images);
const imageSrcs = images.map(i => i.src);
---

<Layout title="promptfolio">
  <header class="frame">
    <h1 class="frame__title">promptfolio</h1>
    <button class="frame__toggle" id="view-toggle" aria-label="Cambiar vista">🌐 3D</button>
  </header>

  <div id="view-grid">
    <Gallery groups={groups} />
  </div>

  <div id="view-canvas" style="display:none">
    <InfiniteCanvas images={imageSrcs} client:only="react" />
  </div>
</Layout>

<script>
  const toggle = document.getElementById('view-toggle');
  const grid = document.getElementById('view-grid');
  const canvas = document.getElementById('view-canvas');

  let is3D = false;

  toggle?.addEventListener('click', () => {
    is3D = !is3D;
    if (is3D) {
      grid.style.display = 'none';
      canvas.style.display = 'block';
      toggle.textContent = '▣ Grid';
      (window as any).__activateCanvas?.();
    } else {
      grid.style.display = '';
      canvas.style.display = 'none';
      toggle.textContent = '🌐 3D';
      (window as any).__deactivateCanvas?.();
    }
  });
</script>

<style>
  .frame {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
    mix-blend-mode: difference;
    color: #fff;
    font-family: var(--font-serif);
  }

  .frame__title {
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 400;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .frame__toggle {
    pointer-events: auto;
    background: none;
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    border-radius: 2px;
    transition: border-color 0.2s;
  }

  .frame__toggle:hover {
    border-color: #fff;
  }
</style>
