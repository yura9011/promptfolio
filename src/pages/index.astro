---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import { getAllImages, groupByDay } from '../lib/images';

const images = getAllImages();
const groups = groupByDay(images);
---

<Layout title="promptfolio">
  <section class="hero">
    <div class="hero__image">
      <img src={images[0]?.src} alt="" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__text">
      <h1 class="hero__title">promptfolio</h1>
      <p class="hero__subtitle">Imágenes generadas · {groups.length} {groups.length === 1 ? 'día' : 'días'}</p>
    </div>
  </section>

  <Gallery groups={groups} />
</Layout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 80vh;
    min-height: 500px;
    max-height: 900px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .hero__image {
    position: absolute;
    inset: 0;
  }

  .hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.6) saturate(0.8);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(11, 11, 11, 0.3) 0%,
      rgba(11, 11, 11, 0.6) 50%,
      rgba(11, 11, 11, 1) 100%
    );
  }

  .hero__text {
    position: absolute;
    bottom: 4rem;
    left: 4rem;
    z-index: 1;
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 400;
    line-height: 1;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.03em;
  }

  .hero__subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin: 0.75rem 0 0;
  }

  @media (max-width: 768px) {
    .hero {
      height: 60vh;
      min-height: 350px;
      margin-bottom: 2rem;
    }
    .hero__text {
      left: 1.5rem;
      bottom: 2rem;
    }
  }
</style>
