---
const { title, day, month, year, dayName } = Astro.props;
---

<div class="day-divider">
  <span class="day-divider__rule"></span>
  <div class="day-divider__text">
    <h2 class="day-divider__date">{day} <span class="day-divider__month">{month}</span></h2>
    <p class="day-divider__weekday">{dayName} · {year}</p>
  </div>
</div>

<style>
  .day-divider {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin: 6rem 0 3rem;
    padding: 0 4rem;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .day-divider:first-of-type {
    margin-top: 0;
  }

  .day-divider__rule {
    flex-shrink: 0;
    width: 3px;
    height: 4.5rem;
    background: var(--ink);
    margin-top: 0.4rem;
  }

  .day-divider__text {
    flex: 1;
  }

  .day-divider__date {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .day-divider__month {
    font-style: italic;
    color: var(--text-muted);
  }

  .day-divider__weekday {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin: 0.5rem 0 0;
  }

  @media (max-width: 768px) {
    .day-divider {
      padding: 0 1.5rem;
      margin: 4rem 0 2rem;
    }
    .day-divider__rule {
      height: 3rem;
    }
  }
</style>
