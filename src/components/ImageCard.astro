---
const { src, title } = Astro.props;
const index = Astro.props.index ?? 0;
---

<figure class="card" data-index={index} data-src={src}>
  <img class="card__image" src={src} alt={title} loading="lazy" />
</figure>

<style>
  .card {
    margin: 0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    aspect-ratio: auto;
    opacity: 0;
    animation: card-in 0.6s ease forwards;
    animation-delay: calc(var(--card-index, 0) * 0.05s);
  }

  .card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, filter 0.6s ease;
  }

  .card:hover .card__image {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  @keyframes card-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
