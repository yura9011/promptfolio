---
const { src, title } = Astro.props;
const index = Astro.props.index ?? 0;
---

<figure class="card" data-index={index} data-src={src}>
  <img class="card__image" src={src} alt={title} loading="lazy" />
</figure>

<style>
  .card {
    margin: 0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .card.expanded {
    grid-column: span 2;
    grid-row: span 2;
  }

  .card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, filter 0.6s ease;
  }

  .card:hover .card__image {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  @media (max-width: 768px) {
    .card.expanded {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
